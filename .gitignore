# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# IDE / OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Runtime outputs
outputs/images/*
outputs/videos/*
